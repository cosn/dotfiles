{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Edit(*)",
      "Write(*)",
      "Update(*)",
      "Read",
      "Bash(bazel:*)",
      "Bash(bun:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(docker:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(go:*)",
      "Bash(grep:*)",
      "Bash(gs:*)",
      "Bash(gt:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(ghostty:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(op:*)",
      "Bash(pkill:*)",
      "Bash(pnpm:*)",
      "Bash(pnpx:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(source:*)",
      "Bash(tail:*)",
      "Bash(temporal:*)",
      "Bash(terraform plan:*)",
      "Bash(touch:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Read(.env)",
      "Read(.env.*)"
    ],
    "ask": [
      "Bash(aws:*)",
      "Bash(curl:*)",
      "Bash(kubectl:*)",
      "Bash(rm:*)",
      "Bash(ssh:*)",
      "Bash(wget:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/cos/.claude/hooks/context-mode-cache-heal.mjs\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "nx@nx-claude-plugins": true,
    "superpowers@claude-plugins-official": true,
    "claude@accrual-dev": true,
    "dev@accrual-dev": true,
    "devbox@accrual-dev": true,
    "metabase@accrual-dev": true,
    "react@accrual-dev": true,
    "tax@accrual-dev": true,
    "team@accrual-dev": true,
    "temporal@accrual-dev": true,
    "claude-notifications-go@claude-notifications-go": true,
    "figma@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "caveman@caveman": true,
    "slack@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "posthog@claude-plugins-official": true,
    "double-shot-latte@superpowers-marketplace": true,
    "andrej-karpathy-skills@karpathy-skills": true,
    "context-mode@context-mode": true,
    "ponytail@ponytail": true
  },
  "extraKnownMarketplaces": {
    "nx-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "nrwl/nx-ai-agents-config"
      },
      "autoUpdate": true
    },
    "accrual-dev": {
      "source": {
        "source": "github",
        "repo": "accrual-dev/claude-marketplace"
      },
      "autoUpdate": true
    },
    "claude-notifications-go": {
      "source": {
        "source": "github",
        "repo": "777genius/claude-notifications-go"
      },
      "autoUpdate": true
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      },
      "autoUpdate": true
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    },
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "awaySummaryEnabled": false,
  "teammateMode": "in-process",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
